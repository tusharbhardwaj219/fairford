# ============================================================================
# FAIR FORD PHARMA - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in actual values
# IMPORTANT: Never commit .env file to version control!
# ============================================================================

# ─── SERVER CONFIGURATION ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb+srv://your_username:your_password@cluster-name.mongodb.net/fairford?retryWrites=true&w=majority

# ─── JWT AUTHENTICATION ──────────────────────────────────────────────────
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── FRONTEND URL ────────────────────────────────────────────────────────
# Used for CORS validation
FRONTEND_URL=http://localhost:5000

# ─── CLOUDINARY (Image Storage) ──────────────────────────────────────────
# Get from: https://cloudinary.com/console/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── EMAIL CONFIGURATION (Nodemailer) ────────────────────────────────────
# Gmail: Use App Password (2FA enabled), NOT your normal password
# Get App Password from: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
ADMIN_EMAIL=admin@fairfordpharma.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ─── OPTIONAL: Redis (for token blacklist, sessions) ────────────────────
# Uncomment when implementing Redis
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# ─── OPTIONAL: Payment Gateway (Stripe, PayPal, etc) ────────────────────
# STRIPE_SECRET_KEY=sk_test_your_stripe_key
# STRIPE_PUBLIC_KEY=pk_test_your_public_key
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_SECRET=your_paypal_secret

# ─── OPTIONAL: SMS/OTP Service ──────────────────────────────────────────
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ─── LOGGING ─────────────────────────────────────────────────────────────
LOG_LEVEL=debug
# Log file path
LOG_FILE=./logs/app.log

# ─── SECURITY ────────────────────────────────────────────────────────────
# Session secret for express-session
SESSION_SECRET=your_session_secret_key_min_32_chars_long

# CORS Origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5000,https://fairfordpharma.com

# ─── RATE LIMITING ───────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# ─── FILE UPLOAD ─────────────────────────────────────────────────────────
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp

# ─── MONITORING & ANALYTICS ──────────────────────────────────────────────
# Sentry error tracking
# SENTRY_DSN=https://key@sentry.io/project-id

# NewRelic APM monitoring
# NEW_RELIC_LICENSE_KEY=your_newrelic_key
# NEW_RELIC_APP_NAME=FairFord-API
